generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(cuid())
  email             String              @unique
  name              String
  passwordHash      String? // null = placeholder user (invited but not yet signed up)
  createdAt         DateTime            @default(now())
  memberships       Membership[]
  environmentAccess EnvironmentAccess[]
}

model Project {
  id           String        @id @default(cuid())
  name         String
  description  String?
  createdAt    DateTime      @default(now())
  memberships  Membership[]
  environments Environment[]
  invitations  Invitation[]
}

// A pending invitation. The owner shares the unique `token` as a link; the
// invitee accepts it (after signing up / logging in) to gain membership.
model Invitation {
  id         String    @id @default(cuid())
  token      String    @unique
  email      String
  role       String // "editor" | "viewer"
  // Environment ids to grant access to when the invite is accepted.
  environmentIds String[] @default([])
  createdAt  DateTime  @default(now())
  acceptedAt DateTime?
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String

  @@index([projectId])
}

// Note: role is stored as a String ("owner" | "editor" | "viewer") and validated
// at the application layer (see lib/authz.ts).
model Membership {
  id        String  @id @default(cuid())
  role      String // "owner" | "editor" | "viewer"
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@unique([userId, projectId])
}

model Environment {
  id        String              @id @default(cuid())
  name      String
  createdAt DateTime            @default(now())
  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  secrets   Secret[]
  access    EnvironmentAccess[]

  @@unique([projectId, name])
}

// Grants a (non-owner) user access to a specific environment. Owners implicitly
// have access to every environment in their project and need no rows here.
model EnvironmentAccess {
  id            String      @id @default(cuid())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  environmentId String
  createdAt     DateTime    @default(now())

  @@unique([userId, environmentId])
  @@index([environmentId])
}

model Secret {
  id            String      @id @default(cuid())
  key           String
  ciphertext    String
  iv            String
  authTag       String
  updatedAt     DateTime    @updatedAt
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  environmentId String

  @@unique([environmentId, key])
}
